# =============================================================================
# .env.example  ->  copiar a .env y completar con TUS valores reales.
#
# ⚠️ REPOSITORIO PÚBLICO: este archivo es solo una PLANTILLA con placeholders.
#    Nunca pongas aquí valores reales (passwords, keys, nombres internos).
#    Esos van únicamente en tu .env local (ignorado por git) en cada server.
# =============================================================================

# ---------------------------------------------------------------------------
# Backblaze B2 (almacenamiento S3-compatible donde viven los dumps)
# ---------------------------------------------------------------------------
B2_BUCKET=mi-bucket-b2
B2_KEY_ID=tu-key-id
B2_APP_KEY=tu-application-key
B2_ENDPOINT=https://s3.us-west-XXX.backblazeb2.com
B2_REGION=us-west-XXX
B2_PREFIX=easypanel-migration

# ---------------------------------------------------------------------------
# MODO DE CONEXIÓN
# EasyPanel corre Docker Swarm. Lo más robusto es el MODO EXEC: entrar al
# contenedor de la BD con `docker exec` (usa su propio pg_dump, versión correcta).
# Define *_PG_CONTAINER con el nombre de SERVICIO (sin el sufijo .1.xxxxx).
#
# El MODO RED (PG_IMAGE + host) solo se usa si NO defines *_PG_CONTAINER.
# Si usas modo red contra un server pg17, pon PG_IMAGE=pgvector/pgvector:pg17.
# ---------------------------------------------------------------------------
PG_IMAGE=pgvector/pgvector:pg17
MIG_DOCKER_NETWORK=

# Servicios a migrar (nombres lógicos, separados por espacio)
DATABASES=chatwoot

# ---------------------------------------------------------------------------
# CHATWOOT  (reemplaza los placeholders por tus valores reales en el .env local)
# ---------------------------------------------------------------------------
CHATWOOT_DB_NAME=nombre_de_tu_bd
# ORIGEN (server viejo) - MODO EXEC. Sustituye <proyecto> por tu proyecto EasyPanel:
CHATWOOT_SRC_PG_CONTAINER=<proyecto>_chatwoot-db
CHATWOOT_SRC_PG_USER=postgres
CHATWOOT_SRC_PG_PASSWORD=pon-el-password-en-tu-env-local
# DESTINO (server nuevo) - se completa cuando exista el servicio allá:
# CHATWOOT_DST_PG_CONTAINER=<proyecto>_chatwoot-db
# CHATWOOT_DST_PG_USER=postgres
# CHATWOOT_DST_PG_PASSWORD=...

# ---------------------------------------------------------------------------
# EVOLUTION API (WhatsApp), si aplica. BD en su propio Postgres.
# Guarda las SESIONES de WhatsApp: si no migra, toca re-escanear QR.
# Para incluirlo, añade 'evolution' a DATABASES y descomenta:
# ---------------------------------------------------------------------------
# EVOLUTION_DB_NAME=nombre_de_tu_bd
# EVOLUTION_SRC_PG_CONTAINER=<proyecto>_evolution-api-db
# EVOLUTION_SRC_PG_USER=postgres
# EVOLUTION_SRC_PG_PASSWORD=...
# EVOLUTION_DST_PG_CONTAINER=<proyecto>_evolution-api-db
# EVOLUTION_DST_PG_USER=postgres
# EVOLUTION_DST_PG_PASSWORD=...

# ---------------------------------------------------------------------------
# Storage local de Chatwoot (Active Storage / adjuntos). Volumen del host.
# Típicamente: /var/lib/docker/volumes/<proyecto>_chatwoot_data/_data
# ---------------------------------------------------------------------------
CHATWOOT_STORAGE_PATH=/var/lib/docker/volumes/<proyecto>_chatwoot_app/_data

# ---------------------------------------------------------------------------
# Chatwoot Active Storage en B2 (Opción C: adjuntos en la nube).
# Mismas variables que se ponen en el servicio Chatwoot (app + sidekiq) en EasyPanel.
# Bucket DISTINTO al de backups (ej. chatwoot-media) + su propia Application Key.
# ---------------------------------------------------------------------------
STORAGE_BUCKET_NAME=chatwoot-media
STORAGE_ACCESS_KEY_ID=keyid-de-la-key-de-media
STORAGE_SECRET_ACCESS_KEY=appkey-de-la-key-de-media
STORAGE_REGION=us-east-005
STORAGE_ENDPOINT=https://s3.us-east-005.backblazeb2.com
STORAGE_FORCE_PATH_STYLE=true

# ---------------------------------------------------------------------------
# NOTAS (no son variables):
# - n8n suele guardar todo en un volumen (SQLite) si no tiene Postgres externo.
#   En ese caso se migra copiando el volumen, no con pg_dump. Ver docs/STORAGE.md.
# - Claves de cifrado a copiar manualmente al destino:
#     Chatwoot: SECRET_KEY_BASE   |   n8n: N8N_ENCRYPTION_KEY
# - Servidor flojo: deja JOBS=1.
# ---------------------------------------------------------------------------
JOBS=1
