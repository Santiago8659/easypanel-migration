# =============================================================================
# .env.example  ->  copiar a .env y completar.   NO commitear .env con secretos.
# =============================================================================

# ---------------------------------------------------------------------------
# Backblaze B2 (almacenamiento S3-compatible donde viven los dumps)
# ---------------------------------------------------------------------------
B2_BUCKET=mi-bucket-b2
B2_KEY_ID=tu-key-id
B2_APP_KEY=tu-application-key
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_REGION=us-west-004
B2_PREFIX=easypanel-migration          # carpeta raíz dentro del bucket

# ---------------------------------------------------------------------------
# Imagen cliente de Postgres. El MAJOR debe ser >= al del servidor de ORIGEN.
# Si tu Chatwoot/n8n corren Postgres 15, usa postgres:15 o superior.
# ---------------------------------------------------------------------------
PG_IMAGE=postgres:16

# Red de Docker para alcanzar la BD (opcional).
#  - Vacío: red bridge por defecto (sirve si la BD está expuesta por IP/puerto público).
#  - En EasyPanel, para alcanzar el contenedor de Postgres por su nombre de
#    servicio, pon aquí el nombre de la red del proyecto (docker network ls).
MIG_DOCKER_NETWORK=

# ---------------------------------------------------------------------------
# Servicios a migrar (nombres lógicos, separados por espacio)
# ---------------------------------------------------------------------------
DATABASES=chatwoot n8n

# ---------------------------------------------------------------------------
# ORIGEN (EasyPanel actual) - credenciales por defecto
# ---------------------------------------------------------------------------
SRC_PG_HOST=
SRC_PG_PORT=5432
SRC_PG_USER=postgres
SRC_PG_PASSWORD=

# ---------------------------------------------------------------------------
# DESTINO (EasyPanel nuevo) - credenciales por defecto
# ---------------------------------------------------------------------------
DST_PG_HOST=
DST_PG_PORT=5432
DST_PG_USER=postgres
DST_PG_PASSWORD=

# ---------------------------------------------------------------------------
# Overrides por servicio (si cada servicio tiene su propio Postgres en EasyPanel)
# Formato: <SERVICIO>_<LADO>_PG_<CAMPO>   y   <SERVICIO>_DB_NAME
# ---------------------------------------------------------------------------
CHATWOOT_DB_NAME=chatwoot
# CHATWOOT_SRC_PG_HOST=chatwoot_postgres
# CHATWOOT_SRC_PG_PASSWORD=...
# CHATWOOT_DST_PG_HOST=chatwoot_postgres
# CHATWOOT_DST_PG_PASSWORD=...

N8N_DB_NAME=n8n
# N8N_SRC_PG_HOST=n8n_postgres
# N8N_SRC_PG_PASSWORD=...
# N8N_DST_PG_HOST=n8n_postgres
# N8N_DST_PG_PASSWORD=...

# ---------------------------------------------------------------------------
# Storage local de Chatwoot (Active Storage local). Ruta del volumen en el host.
# Hoy es local; a futuro se puede mover a B2/S3 (ver docs/STORAGE.md).
# ---------------------------------------------------------------------------
CHATWOOT_STORAGE_PATH=

# ---------------------------------------------------------------------------
# Servidor flojo: deja JOBS=1 (sin paralelismo) para no saturar CPU/RAM.
# Súbelo solo si el server aguanta.
# ---------------------------------------------------------------------------
JOBS=1
